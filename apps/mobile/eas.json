{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "monorepo": {
      "pnpm": "8.6.10",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true"
      }
    },
    "development": {
      "extends": "monorepo",
      "developmentClient": false,
      "distribution": "internal"
    },
    "preview": {
      "extends": "monorepo",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "monorepo",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true
    }
  }
}
