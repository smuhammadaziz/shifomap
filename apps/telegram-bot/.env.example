# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# Group chat ID where clinic notifications and support messages are sent (e.g. -1001234567890)
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# MongoDB (same DB as api-main; telegram_users collection)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=projects

# OpenAI API (for "Shaxsiy doktor" AI feature). Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
